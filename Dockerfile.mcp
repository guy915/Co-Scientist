# syntax=docker/dockerfile:1
# Build from repo root: docker build -f Dockerfile.mcp .
FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y build-essential && rm -rf /var/lib/apt/lists/*

COPY engine/mcp_server/ ./mcp_server/
RUN pip install --no-cache-dir -e ./mcp_server

ENV PYTHONUNBUFFERED=1

EXPOSE ${PORT:-8888}

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import os, httpx; httpx.get(f\"http://localhost:{os.environ.get('PORT', '8888')}\", timeout=5.0)" || exit 1

CMD ["sh", "-c", "uvicorn mcp_server.server:app --host 0.0.0.0 --port ${PORT:-8888}"]
