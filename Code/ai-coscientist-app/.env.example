# LLM Configuration
MODEL_NAME=gemini/gemini-2.5-flash
GEMINI_API_KEY=your_api_key_here

# MCP Server Configuration (required for literature review tools)
# MCP_SERVER_URL: URL of the MCP server providing literature review tools
# Default xfarscape server runs on http://localhost:8888/mcp
# Leave empty or comment out to disable literature review (graceful degradation)
MCP_SERVER_URL=http://localhost:8888/mcp

# Server Configuration
HOST=0.0.0.0
PORT=8008

DEBUG=FALSE

# set to true during development if your OS, AV, proxy, etc, is causing issues when using PubMed search
DISABLE_SSL_VERIFY=false

# Default open-coscientist Configuration
MAX_ITERATIONS=3
INITIAL_HYPOTHESES_COUNT=5
EVOLUTION_MAX_COUNT=3

# Literature Review Configuration (optional)
# Number of papers to read and analyze in literature review node
# Default: 10 (conservative for development)
# Production: 20-50 recommended for proper coverage, better hypotheses, backed by better literture review
# Note: more papers = higher cost + longer time; more quality
COSCIENTIST_LIT_REVIEW_PAPERS_COUNT=10

# Cache Configuration (optional)
COSCIENTIST_CACHE_ENABLED=true
COSCIENTIST_CACHE_DIR=./cache

# Tools Configuration (optional)
# Path to a YAML tools config file for the hypothesis generator.
# Accepts: relative path (from server working dir), absolute path, or http(s):// URL.
# Leave unset to use the generator's default (no tools config).
# TOOLS_CONFIG=./config/my_tools.yaml
# TOOLS_CONFIG=/absolute/path/to/tools.yaml
# TOOLS_CONFIG=https://example.com/tools.yaml
