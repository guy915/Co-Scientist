# open coscientist mcp server environment configuration
# copy this file to .env and fill in your configuration

# ===== Required Configuration =====

# pubmed search (via ncbi entrez)
# required - used for pubmed api identification
ENTREZ_EMAIL=your_email@example.com
ENTREZ_API_KEY=

# literature review cache directory
# where downloaded papers and metadata are stored
COSCIENTIST_LIT_REVIEW_DIR=./paper_cache

# server port
COSCIENTIST_MCP_PORT=8888
COSCIENTIST_MCP_LOG_LEVEL=INFO

# ===== INDRA CoGex Knowledge Graph =====

# INDRA CoGex API base URL (default: public instance)
# INDRA_COGEX_URL=https://discovery.indra.bio

# request timeout in seconds (some queries on large networks can be slow)
# INDRA_COGEX_TIMEOUT=60