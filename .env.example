# AI Co-Scientist — root environment defaults
# Copy to .env. With no keys set, the system runs in deterministic Mock Mode.

# ----- LLM provider keys (optional; absence triggers Mock Mode) -----
# Any one of these unlocks the real engine. Otherwise the backend serves the
# deterministic mock workflow reported by /status.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Default model. LiteLLM-format. Used by the real engine path only.
# Examples: deepseek/deepseek-chat, gemini/gemini-2.5-flash, openai/gpt-4o
MODEL_NAME=deepseek/deepseek-chat

# ----- Storage -----
# SQLite path for runs, events, hypotheses, evidence, matches, reports.
# Default lives at the repo root for easy reset via `make reset-db`.
COSCIENTIST_DB_PATH=./coscientist.db

# Markdown reports + JSON exports land here.
COSCIENTIST_REPORTS_DIR=./reports

# ----- Server -----
HOST=0.0.0.0
PORT=8008
DEBUG=false

# CORS allowlist for the UI dev server.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ----- Engine defaults (overridable per-run from the UI) -----
MAX_ITERATIONS=2
INITIAL_HYPOTHESES_COUNT=5
EVOLUTION_MAX_COUNT=2

# ----- Optional MCP (literature retrieval) -----
# Leave blank to run without literature tools (mock mode supplies stub evidence).
MCP_SERVER_URL=

# ----- Cache -----
COSCIENTIST_CACHE_ENABLED=true
COSCIENTIST_CACHE_DIR=./cache

# ----- Elo / tournament tuning -----
ELO_INITIAL=1200
ELO_K_FACTOR=24

# ----- Safety -----
SAFETY_MODE=standard
